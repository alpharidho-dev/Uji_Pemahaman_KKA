def register():
    nama = input("Masukkan nama: ")
    username = input("Masukkan username: ")
    gmail = input("Masukkan gmail: ")
    password = input("Masukkan password: ")
    
    hashed = hash_password(password)
    
    with open(USER_FILE, "r") as file:
        data = json.load(file)
    
    data.append({
        "nama": nama,
        "username": username,
        "gmail": gmail,
        "password": hashed
    })
    
    with open(USER_FILE, "w") as file:
        json.dump(data, file, indent=4)
    ketik("Registrasi berhasil!")
    time.sleep(1)
    clear_screen()
    
def login():
    username = input("Masukkan username: ")
    password = input("Masukkan password: ")
    hashed_input = hashlib.sha256(password.encode()).hexdigest()
    
    with open(USER_FILE, "r") as file:
        data_dimuat = json.load(file)
        
    for user in data_dimuat:
        if user["username"] == username and user["password"] == hashed_input:
                ketik("Login berhasil!")
                time.sleep(1)
                clear_screen()
                return True
    ketik("Username atau password salah!")
    time.sleep(1)
    clear_screen()    
    return False

