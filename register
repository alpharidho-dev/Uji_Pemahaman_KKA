    {
        "nama": "Budi",
        "username": "budi123",
        "gmail": "budi123@gmail.com",
        "password": hash_password("budbudi")
    }
]

# fungsi buat clear
def clear_screen():
    os.system('cls' if os.name == 'nt' else 'clear')
    
    
# fungsi buat animasi ketik
def ketik(teks, kecepatan=0.05):
    
    for huruf in teks:
        print(huruf, end="", flush=True) 
        time.sleep(kecepatan)
    print()
    
    
